# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Google Gemini API (Google AI Studio / ai.google.dev)
# 注意: このAPIキーを発行したGoogle Cloudプロジェクトには請求先アカウントを紐付けないこと。
# 紐付けない限り、無料枠のレート制限を超えても課金は発生せずエラーになるだけ。
GEMINI_API_KEY=

# Neon Postgres
DATABASE_URL=

# Google OAuth (Calendar連携)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-render-host/auth/google/callback

# 外部cron (cron-job.orgなど) からの呼び出しを保護する共有シークレット
CRON_SECRET=

# サーバーポート (Renderは自動でPORTを注入するが、ローカル実行用にデフォルトを用意)
PORT=3000
